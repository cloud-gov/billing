    {
      "name": "public.reading",
      "type": "BASE TABLE",
      "columns": [
        {
          "name": "id",
          "type": "integer",
          "nullable": false,
          "default": "nextval('reading_id_seq'::regclass)"
        },
        {
          "name": "created_at",
          "type": "timestamp without time zone",
          "nullable": false,
          "comment": "CreatedAt must be a time in UTC."
        },
        {
          "name": "periodic",
          "type": "boolean",
          "nullable": false,
          "comment": "Periodic is true if a reading was taken automatically as part of the periodic usage measurement schedule, or false if it was requested manually."
        },
        {
          "name": "created_at_utc",
          "type": "timestamp with time zone",
          "nullable": true,
          "extra_def": "GENERATED ALWAYS AS (created_at AT TIME ZONE 'UTC'::text) STORED",
          "comment": "CreatedAtUTC supplements CreatedAt, which does not have a timezone. Values must be inserted into CreatedAt in UTC by the client. CreatedAt has a unique index on it to enforce readings being taken at most hourly. Because the index uses functions that are not volatility level IMMUTABLE, it cannot be used on a column with a timezone; hence the supplementary generated column."
        }
      ],
      "indexes": [
        {
          "name": "reading_pkey",
          "def": "CREATE UNIQUE INDEX reading_pkey ON public.reading USING btree (id)",
          "table": "public.reading",
          "columns": [
            "id"
          ]
        },
        {
          "name": "idx_reading_created_at",
          "def": "CREATE INDEX idx_reading_created_at ON public.reading USING btree (created_at)",
          "table": "public.reading",
          "columns": [
            "created_at"
          ]
        },
        {
          "name": "reading_hourly_uq",
          "def": "CREATE UNIQUE INDEX reading_hourly_uq ON public.reading USING btree (date_trunc('hour'::text, created_at))",
          "table": "public.reading",
          "columns": [
            "date_trunc"
          ],
          "comment": "Make readings unique per hour."
        },
        {
          "name": "reading_created_at_idx",
          "def": "CREATE INDEX reading_created_at_idx ON public.reading USING btree (created_at)",
          "table": "public.reading",
          "columns": [
            "created_at"
          ]
        },
        {
          "name": "reading_created_at_utc_idx",
          "def": "CREATE INDEX reading_created_at_utc_idx ON public.reading USING btree (created_at_utc)",
          "table": "public.reading",
          "columns": [
            "created_at_utc"
          ]
        }
      ],
