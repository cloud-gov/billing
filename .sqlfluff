[sqlfluff]
dialect = postgres

[sqlfluff:indentation]
tab_space_size = 2
indent_unit = space
indented_using_on = true
indented_on_contents = true
allow_implicit_indents = true
indented_joins = true
indented_ctes = true

[sqlfluff:layout:type:column]
spacing_before = align
align_within = statement
align_scope = file

[sqlfluff:layout:type:column_definition]
spacing_before = align
align_within = statement
align_scope = brackets

[sqlfluff:layout:type:column_constraint_segment]
spacing_before = align
align_within = statement
align_scope = file

[sqlfluff:layout:type:data_type]
spacing_before = align
align_within = statement
align_scope = file

[sqlfluff:layout:type:start_square_bracket]
spacing_before = touch
spacing_after = touch

[sqlfluff:rules:layout.long_lines]
ignore_comment_clauses = true
ignore_comment_lines = true

[sqlfluff:rules:references.keywords]
ignore_words = path
